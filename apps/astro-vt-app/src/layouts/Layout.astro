---
// Корневой layout Astro VT — добавляет <ViewTransitions /> для SPA-навигации.
import { ViewTransitions } from 'astro:transitions';
interface Props {
    title?: string;
}
const { title = 'Тестовый стенд — Astro VT' } = Astro.props;
---
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="stylesheet" href="/shared/global.css" />
    <ViewTransitions />
</head>
<body>
    <div class="layout-container">
        <header class="app-header">
            <h1 class="app-title">Тестовый стенд</h1>
            <div class="framework-badge">Astro VT</div>
            <div class="routing-tech">Astro MPA + View Transitions (SPA-навигация)</div>
        </header>
        <slot />
    </div>
    <script>
        import '../scripts/initial-load-metrics.js';
    </script>
</body>
</html>
