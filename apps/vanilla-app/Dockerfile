# Формирование контейнера Vanilla JS приложения.
FROM node:20-alpine

# Инициализация рабочей директории приложения.
WORKDIR /app

# Объявление build-аргумента публичного идентификатора SUT.
ARG SUT_ID=vanilla_app

# Экспорт build-аргумента в переменную окружения.
ENV SUT_ID=$SUT_ID

# Копирование файлов зависимостей приложения.
COPY package.json ./

# Копирование исходного кода и ассетов приложения.
COPY . .

# Декларация сетевого порта приложения.
EXPOSE 3000

# Запуск сервера Vanilla JS (без build-шага — runtime только).
CMD ["node", "server.js"]
